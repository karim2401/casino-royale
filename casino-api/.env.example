# ═══════════════════════════════════════════════════════════════
#  Casino Royale API — Environment Variables Template
#  Copy this file to .env and fill in the values
#  ⚠️  Never commit .env to Git — only .env.example
# ═══════════════════════════════════════════════════════════════

# ─── DATABASE ──────────────────────────────────────────────────
# Local Docker (see README Step 2):
DATABASE_URL=postgresql://casino:casino123@localhost:5433/casino_royale
#
# Railway (auto-provided — leave as-is in Railway dashboard):
# DATABASE_URL=  ← Railway injects this automatically
#
# Neon (free cloud alternative):
# DATABASE_URL=postgresql://user:pass@ep-xxx.neon.tech/neondb?sslmode=require

# ─── JWT ───────────────────────────────────────────────────────
# Generate a strong secret for production:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=casino_royale_dev_secret_change_in_production_2026
JWT_EXPIRES_IN=7d

# ─── SERVER ────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ─── CORS ──────────────────────────────────────────────────────
# Local: use * or http://localhost:8080
# Production: set to your actual frontend URL
FRONTEND_ORIGIN=*
